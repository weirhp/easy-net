# 宿主机映射端口
HOST_PORT=3100

# 服务统一路径前缀，例如 /easy-net。留空表示不加前缀。
CONTEXT_PATH=/easy-net

# 初始管理员密码。仅首次创建 data/easy-net.sqlite 时生效。
ADMIN_PASSWORD=change-this-admin-password

# 客户端配置中写入的完整 WebSocket 地址
CLIENT_WS_URL=wss://proxy.example.com/easy-net/tunnel

# 旧版兼容：客户端配置中写入的服务器域名或 host:port
CLIENT_HOST=proxy.example.com:3100

# 客户端配置中写入的本地 SOCKS 端口
CLIENT_LOCAL_PORT=1080

# 登录失败锁定策略
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_MINUTES=15

# 旧版兼容：首次启动时会把这些密钥迁移为 legacy 用户，之后推荐在管理端维护。
SECRETS=

# 旧版兼容：仍可用于 /stats?admin_key=...
ADMIN_KEY=your-admin-stat-key
